{
  "name": "hfp-root",
  "version": "1.0.0",
  "description": "Heart Failure Prediction App Runner",
  "scripts": {
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "cd backend && ./venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000",
    "start:frontend": "cd frontend && npm run dev",
    "install:all": "cd frontend && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
